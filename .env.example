# Plantilla de variables de entorno. Copia este archivo a `.env` y completa los valores.
# El `.env` real está en .gitignore y NO se sube al repo.

# API key de Google Maps Geocoding (dirección -> lat/long).
# Crear en https://console.cloud.google.com -> habilitar "Geocoding API" + facturación.
GOOGLE_MAPS_API_KEY=
